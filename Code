    public static final String PLATFORM_NAME = "PakWheels Clone"; // constant

    private Listing[] listings     = new Listing[MAX_LISTINGS];
    private int       listingCount = 0;

    public void addListing(Listing l) {
        if (listingCount < MAX_LISTINGS) listings[listingCount++] = l;
    }

    // Polymorphism: Method Overloading (Requirement 2)
    // 4 overloaded versions of search() with different signatures

    public void search(String brand) {
        System.out.println("=== Results for Brand: " + brand + " ===");
        for (int i = 0; i < listingCount; i++)
            if (listings[i].getVehicle().getBrand().equalsIgnoreCase(brand))
                listings[i].displayListing();
    }

    public void search(String brand, double maxPrice) {
        System.out.println("=== Results: " + brand + " under PKR " + maxPrice + " ===");
        for (int i = 0; i < listingCount; i++) {
            Vehicle v = listings[i].getVehicle();
            if (v.getBrand().equalsIgnoreCase(brand) && v.getPrice() <= maxPrice)
                listings[i].displayListing();
        }
    }

    public void search(String brand, int year) {
        System.out.println("=== Results: " + brand + " (" + year + ") ===");
        for (int i = 0; i < listingCount; i++) {
            Vehicle v = listings[i].getVehicle();
            if (v.getBrand().equalsIgnoreCase(brand) && v.getYear() == year)
                listings[i].displayListing();
        }
    }

    public void search(double minPrice, double maxPrice) {
        System.out.println("=== Results: PKR " + minPrice + " – " + maxPrice + " ===");
        for (int i = 0; i < listingCount; i++) {
            double p = listings[i].getVehicle().getPrice();
            if (p >= minPrice && p <= maxPrice)
                listings[i].displayListing();
        }
    }

    public void searchWithFilter(AbstractFilter filter) {


        //  LOCAL INNER CLASS: ResultFormatter  (Requirement 6)
        //  Defined inside this method because it's only used here to format
        //  filter search output.  It cannot be reused elsewhere by design.

        class ResultFormatter {
            void printHeader() {
                System.out.println("================================================");
                filter.displayFilterCriteria();
                System.out.println("------------------------------------------------");
            }
            void printFooter(int count) {
                System.out.println("------------------------------------------------");
                System.out.println("Total matches: " + count);
                System.out.println("================================================");
            }
        }

        ResultFormatter fmt = new ResultFormatter();
        fmt.printHeader();
        int count = 0;
        for (int i = 0; i < listingCount; i++)
            if (filter.applyFilter(listings[i].getVehicle())) {
                listings[i].displayListing();
                count++;
            }
        fmt.printFooter(count);
    }

    public void displayAll() {
        System.out.println("=== All Listings on " + PLATFORM_NAME + " ===");
        for (int i = 0; i < listingCount; i++) listings[i].displayListing();
    }

    //  STATIC NESTED CLASS: Statistics  (Requirement 6)
    //  Does not need a Marketplace instance – it reads class-level counters.
    //  Making it static avoids an unnecessary outer reference.

    static class Statistics {
        public static int  getTotalUsers()    { return User.totalUsers;    }
        public static int  getTotalListings() { return Listing.totalListings; }

        public static void display() {
            System.out.println("=== Marketplace Statistics ===");
            System.out.println("  Total Users:    " + getTotalUsers());
            System.out.println("  Total Listings: " + getTotalListings());
        }
    }
