//  INTERFACES (Requirement 4)

// Interface 1: Taxable – implemented by Vehicle subclasses
// Represents any entity on which tax can be calculated
interface Taxable {
    double calculateTax();
    double getTaxRate();
}

// Interface 2: Discountable – applied to vehicles that support price discounts
interface Discountable {
    double applyDiscount(double rate);
    double getDiscountedPrice();
}

// Interface 3: Searchable – anything that can be matched against a query string
interface Searchable {
    boolean matches(String query);
}

// Interface 4: Rateable – users and sellers can be rated (1-5 stars)
interface Rateable {
    void rate(int stars);
    double getAverageRating();
}

//  ABSTRACT CLASS 1: User (Requirement 3)
//  Base for Buyer, Seller, Admin

abstract class User implements Rateable {
    protected int    userId;
    protected String name;
    protected String email;
    protected String phone;
    protected String city;

    public static int totalUsers = 0;

    private int[] ratings     = new int[200];
    private int   ratingCount = 0;

    public User(int userId, String name, String email, String phone, String city) {
        this.userId = userId;
        this.name   = name;
        this.email  = email;
        this.phone  = phone;
        this.city   = city;
        totalUsers++;
    }

    public abstract String getRole();
    public abstract void   displayDetails();

    public void displayUser() {
        System.out.println("[" + getRole() + "] " + name
                + "  Email: " + email + "  City: " + city);
    }

    @Override
    public void rate(int stars) {
        if (stars >= 1 && stars <= 5 && ratingCount < ratings.length)
            ratings[ratingCount++] = stars;
    }

    @Override
    public double getAverageRating() {
        if (ratingCount == 0) return 0;
        int sum = 0;
        for (int i = 0; i < ratingCount; i++) sum += ratings[i];
        return (double) sum / ratingCount;
    }

    public String getName()    { return name;   }
    public int    getUserId()  { return userId; }
    public String getEmail()   { return email;  }
}

