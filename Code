//  GENERIC CLASS: DataStore<T>  (Requirement 5)
//  A type-safe, reusable container that works with any object type
//  Supports add, get, search, swap, and display operations

class DataStore<T> {
    private Object[] data;
    private int      size;
    private int      capacity;

    public DataStore(int capacity) {
        this.capacity = capacity;
        this.data     = new Object[capacity];
        this.size     = 0;
    }

    public boolean add(T item) {
        if (size < capacity) { data[size++] = item; return true; }
        return false;
    }

    @SuppressWarnings("unchecked")
    public T get(int index) {
        return (index >= 0 && index < size) ? (T) data[index] : null;
    }

    public int getSize() { return size; }

    // Generic method 1: search using a Predicate condition

    @SuppressWarnings("unchecked")
    public T search(Predicate<T> condition) {
        for (int i = 0; i < size; i++) {
            T item = (T) data[i];
            if (condition.test(item)) return item;
        }
        return null;
    }

    // Generic method 2: swap two elements at given indices

    public void swap(int i, int j) {
        if (i >= 0 && j >= 0 && i < size && j < size) {
            Object tmp = data[i];
            data[i]    = data[j];
            data[j]    = tmp;
        }
    }

    @SuppressWarnings("unchecked")
    public void displayAll(String label) {
        System.out.println("=== " + label + " ===");
        for (int i = 0; i < size; i++) System.out.println("  " + data[i]);
    }
}

//  GENERIC UTILITY METHODS  (Requirement 5)

class GenericUtils {

    // Generic method 3: bubble-sort any Vehicle array by ascending price

    public static <T extends Vehicle> void sortByPrice(T[] arr, int count) {
        for (int i = 0; i < count - 1; i++)
            for (int j = 0; j < count - i - 1; j++)
                if (arr[j].getPrice() > arr[j + 1].getPrice()) {
                    T tmp    = arr[j];
                    arr[j]   = arr[j + 1];
                    arr[j+1] = tmp;
                }
    }

    // Generic swap utility

    public static <T> void swap(T[] arr, int i, int j) {
        T tmp  = arr[i];
        arr[i] = arr[j];
        arr[j] = tmp;
    }

    // Find cheapest vehicle in an array

    public static <T extends Vehicle> T findCheapest(T[] arr, int count) {
        if (count == 0) return null;
        T cheapest = arr[0];
        for (int i = 1; i < count; i++)
            if (arr[i].getPrice() < cheapest.getPrice()) cheapest = arr[i];
        return cheapest;
    }
}

