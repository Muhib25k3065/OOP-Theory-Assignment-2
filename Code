//  ABSTRACT CLASS 2: Vehicle (Requirement 3)
//  Abstract because we never sell a plain "vehicle" – always a Car or Bike
//  Implements Taxable, Discountable, Searchable interfaces

abstract class Vehicle implements Taxable, Discountable, Searchable {

    protected String brand;
    protected String model;
    protected int    year;
    protected double price;
    protected double mileage;
    protected Engine engine;
    protected Specification spec;     // MEMBER INNER CLASS instance

    public Vehicle(String brand, String model, int year,
                   double price, double mileage, Engine engine) {
        this.brand   = brand;
        this.model   = model;
        this.year    = year;
        this.price   = price;
        this.mileage = mileage;
        this.engine  = engine;
        this.spec    = new Specification("White", "Automatic");
    }

    public abstract void   displayDetails();
    public abstract String getVehicleType();

    @Override public double getTaxRate()    { return 0.10; }          // 10 % default
    @Override public double calculateTax()  { return price * getTaxRate(); }

    private double discountRate = 0;

    @Override
    public double applyDiscount(double rate) {
        this.discountRate = rate;
        return price * (1 - rate);
    }

    @Override
    public double getDiscountedPrice() { return price * (1 - discountRate); }

    @Override
    public boolean matches(String query) {
        return brand.equalsIgnoreCase(query) || model.equalsIgnoreCase(query);
    }

    public void   updatePrice(double newPrice) { this.price = newPrice; }
    public String getBrand()   { return brand;   }
    public String getModel()   { return model;   }
    public int    getYear()    { return year;    }
    public double getPrice()   { return price;   }
    public double getMileage() { return mileage; }

    //  MEMBER INNER CLASS: Specification (Requirement 6)
    //  This inner class is a member of Vehicle because each vehicle instance
    //  owns exactly one Specification; it needs no reason to exist independently

    class Specification {
        String  color;
        String  transmission;
        boolean sunroof;
        String  condition;

        Specification(String color, String transmission) {
            this.color        = color;
            this.transmission = transmission;
            this.sunroof      = false;
            this.condition    = "Used";
        }

        void displaySpec() {
            System.out.println("  Color: " + color
                    + "  Transmission: " + transmission
                    + "  Condition: " + condition);
        }
    }
}

